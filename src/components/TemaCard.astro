---
import type { Tema } from '../lib/types';
import { getLibrosByTema, getMeditacionesByTema, contarEpisodiosPorTema } from '../lib/datos';

interface Props {
  tema: Tema;
}

const { tema } = Astro.props;
const libros = getLibrosByTema(tema.slug);
const meditaciones = getMeditacionesByTema(tema.slug);
const totalTitulos = libros.length + meditaciones.length;
const totalEpisodios = contarEpisodiosPorTema(tema.slug);
const imageSrc = `/images/temas/${tema.slug}.webp`;
---

<a
  href={`/temas/${tema.slug}/`}
  class="group block rounded-xl overflow-hidden relative"
>
  <div class="aspect-[16/10] overflow-hidden">
    <img
      src={imageSrc}
      alt={tema.nombre}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent"></div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 p-5">
    <h3 class="font-display text-xl font-bold text-brand-50 group-hover:text-accent transition-colors duration-300">
      {tema.nombre}
    </h3>
    <p class="text-sm text-brand-50/70 mt-1 line-clamp-2 leading-relaxed">{tema.descripcion}</p>

    <div class="flex items-center gap-3 mt-3 text-xs text-brand-50/50">
      <span>{totalTitulos} {totalTitulos === 1 ? 'titulo' : 'titulos'}</span>
      <span class="w-1 h-1 rounded-full bg-accent/50"></span>
      <span>{totalEpisodios} episodios</span>
    </div>
  </div>
</a>
