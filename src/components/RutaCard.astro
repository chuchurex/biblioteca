---
import type { Ruta } from '../lib/types';
import { getTemaBySlug } from '../lib/datos';

interface Props {
  ruta: Ruta;
  href: string;
}

const { ruta, href } = Astro.props;
const temas = ruta.temas.map(s => getTemaBySlug(s)).filter(Boolean);

const imageSrc = `/images/rutas/${ruta.slug}.webp`;
---

<a
  href={href}
  class="group block rounded-xl overflow-hidden relative hover:-translate-y-1 hover:shadow-card-hover transition-all duration-400"
>
  <div class="aspect-[16/9] overflow-hidden">
    <img
      src={imageSrc}
      alt={ruta.titulo}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/50 to-black/10"></div>
  </div>

  {ruta.duracion_estimada && (
    <div class="absolute top-4 left-4">
      <span class="text-[11px] text-white/70 backdrop-blur-sm bg-black/30 px-2 py-1 rounded">{ruta.duracion_estimada}</span>
    </div>
  )}

  <div class="absolute bottom-0 left-0 right-0 p-5">
    <h3 class="font-display text-xl font-bold text-brand-50 group-hover:text-accent transition-colors duration-300 leading-tight">
      {ruta.titulo}
    </h3>
    <p class="text-[13px] text-brand-50/70 mt-1.5 line-clamp-2 leading-relaxed">{ruta.descripcion}</p>

    <div class="flex items-center justify-between mt-3 pt-3 border-t border-white/[0.08]">
      <div class="flex gap-1">
        {ruta.pasos.map(() => (
          <div class="w-5 h-[3px] rounded-full bg-accent/60"></div>
        ))}
      </div>
      <span class="text-xs text-brand-50/50">{ruta.pasos.length} pasos</span>
    </div>
  </div>
</a>
