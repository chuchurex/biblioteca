---
interface FranjaItem {
  titulo: string;
  thumbnail: string;
  href: string;
  videoCount?: number;
  badge?: string;
}

interface Props {
  titulo: string;
  href: string;
  items: FranjaItem[];
}

const { titulo, href, items } = Astro.props;

if (items.length === 0) return null;
---

<section class="py-6">
  <div class="container mx-auto px-4 md:px-8">
    <div class="flex items-baseline justify-between mb-4">
      <h2 class="text-2xl font-bold text-brand-800">
        <a href={href} class="hover:text-brand-600 transition">{titulo}</a>
      </h2>
      {items.length > 1 && (
        <a href={href} class="text-sm text-brand-500 hover:text-brand-700 transition whitespace-nowrap">
          Ver todos &rarr;
        </a>
      )}
    </div>

    <div class="franja-container relative group/franja">
      <!-- Left arrow -->
      <button
        class="franja-arrow franja-left hidden md:flex absolute left-0 top-1/2 -translate-y-1/2 z-10 w-10 h-10 bg-black/60 hover:bg-black/80 text-white rounded-full items-center justify-center opacity-0 group-hover/franja:opacity-100 transition-opacity -ml-3"
        aria-label="Anterior"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>

      <!-- Scrollable row -->
      <div class="franja-scroll flex gap-4 overflow-x-auto snap-x snap-mandatory pb-2 scrollbar-hide">
        {items.map((item) => (
          <div class="snap-start flex-shrink-0 w-[260px] md:w-[300px]">
            <a href={item.href} class="group block bg-white rounded-xl shadow-card overflow-hidden hover:-translate-y-0.5 hover:shadow-card-hover transition-all duration-300">
              <div class="relative aspect-video overflow-hidden">
                <img
                  src={item.thumbnail}
                  alt={item.titulo}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
                {item.badge && (
                  <span class="absolute top-2 right-2 bg-brand-400 text-white text-xs font-bold px-2.5 py-1 rounded-full shadow-md uppercase tracking-wide">
                    {item.badge}
                  </span>
                )}
                {item.videoCount && item.videoCount > 1 && (
                  <span class="absolute bottom-2 right-2 bg-black/80 text-white text-sm px-2 py-0.5 rounded">
                    {item.videoCount} videos
                  </span>
                )}
                <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300 flex items-center justify-center">
                  <svg class="w-10 h-10 text-white opacity-0 group-hover:opacity-90 transition-opacity duration-300 drop-shadow-lg" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </div>
              </div>
              <div class="p-3">
                <h3 class="text-base font-medium text-brand-800 group-hover:text-brand-600 transition-colors line-clamp-2">
                  {item.titulo}
                </h3>
              </div>
            </a>
          </div>
        ))}
      </div>

      <!-- Right arrow -->
      <button
        class="franja-arrow franja-right hidden md:flex absolute right-0 top-1/2 -translate-y-1/2 z-10 w-10 h-10 bg-black/60 hover:bg-black/80 text-white rounded-full items-center justify-center opacity-0 group-hover/franja:opacity-100 transition-opacity -mr-3"
        aria-label="Siguiente"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
  document.querySelectorAll('.franja-container').forEach(container => {
    const scroll = container.querySelector('.franja-scroll') as HTMLElement;
    const leftBtn = container.querySelector('.franja-left');
    const rightBtn = container.querySelector('.franja-right');
    const amount = 316;

    leftBtn?.addEventListener('click', () => {
      scroll.scrollBy({ left: -amount, behavior: 'smooth' });
    });
    rightBtn?.addEventListener('click', () => {
      scroll.scrollBy({ left: amount, behavior: 'smooth' });
    });
  });
</script>
