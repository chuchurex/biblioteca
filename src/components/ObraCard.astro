---
import type { Obra } from '../lib/types';
import { contarEpisodiosObra } from '../lib/datos';

interface Props {
  obra: Obra;
  href: string;
}

const { obra, href } = Astro.props;
const totalEps = contarEpisodiosObra(obra);
const multiVersion = obra.versiones.length > 1;
---

<a
  href={href}
  class="group block bg-white rounded-xl shadow-card overflow-hidden hover:-translate-y-0.5 hover:shadow-card-hover transition-all duration-300"
>
  {obra.thumbnail && (
    <div class="aspect-video bg-brand-100 overflow-hidden relative">
      <img
        src={obra.thumbnail}
        alt={obra.titulo}
        class="w-full h-full object-cover group-hover:scale-105 transition duration-300"
        loading="lazy"
      />
      <div class="absolute bottom-2 right-2 flex gap-1.5">
        {multiVersion && (
          <span class="bg-brand-600/90 text-white text-xs px-2 py-1 rounded font-medium">
            {obra.versiones.length} versiones
          </span>
        )}
        <span class="bg-black/70 text-white text-xs px-2 py-1 rounded">
          {totalEps} {totalEps === 1 ? 'episodio' : 'episodios'}
        </span>
      </div>
    </div>
  )}
  <div class="p-4">
    <div class="flex flex-wrap gap-1.5 mb-2">
      <span class="text-[11px] font-medium px-2 py-0.5 rounded-full bg-brand-100 text-brand-600">
        Audiolibro
      </span>
    </div>
    <h3 class="font-semibold text-brand-800 group-hover:text-brand-600 transition line-clamp-2">
      {obra.titulo}
    </h3>
    <p class="text-sm text-brand-500 mt-1">{obra.autor}</p>
    {!obra.thumbnail && (
      <p class="text-xs text-brand-400 mt-1">
        {totalEps} {totalEps === 1 ? 'episodio' : 'episodios'}
        {multiVersion && ` · ${obra.versiones.length} versiones`}
      </p>
    )}
  </div>
</a>
