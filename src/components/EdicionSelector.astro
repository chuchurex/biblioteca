---
import type { Canal, Episode } from '../lib/types';
import type { EdicionData } from '../lib/datos';
import EpisodeCard from './EpisodeCard.astro';

interface Props {
  ediciones: EdicionData[];
  basePath: string;
}

const { ediciones, basePath } = Astro.props;
const multiEdicion = ediciones.length > 1;
---

{multiEdicion ? (
  <div class="edicion-selector">
    <div class="flex flex-wrap gap-2 mb-8" role="tablist">
      {ediciones.map((ed, i) => (
        <button
          role="tab"
          aria-selected={i === 0 ? "true" : "false"}
          data-tab={i}
          class:list={[
            "px-5 py-2.5 rounded-lg text-sm font-medium transition-all duration-300",
            i === 0
              ? "bg-accent text-brand-700 shadow-glow"
              : "bg-brand-500 text-brand-100 hover:bg-brand-300"
          ]}
        >
          {ed.edicion.nombre} ({ed.episodios.length} eps)
        </button>
      ))}
    </div>

    {ediciones.map((ed, i) => (
      <div
        role="tabpanel"
        data-panel={i}
        class:list={[i !== 0 && "hidden"]}
      >
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          {ed.episodios.map(ep => (
            <EpisodeCard
              episode={ep}
              href={`${basePath}/${ep.video_id}`}
              canalNombre={ed.canal?.nombre}
            />
          ))}
        </div>
      </div>
    ))}

    <script>
      document.querySelectorAll('.edicion-selector').forEach(selector => {
        const tabs = selector.querySelectorAll('[role="tab"]');
        const panels = selector.querySelectorAll('[role="tabpanel"]');

        tabs.forEach(tab => {
          tab.addEventListener('click', () => {
            const idx = tab.getAttribute('data-tab');

            tabs.forEach(t => {
              t.setAttribute('aria-selected', 'false');
              t.classList.remove('bg-accent', 'text-brand-700', 'shadow-glow');
              t.classList.add('bg-brand-500', 'text-brand-100');
            });
            tab.setAttribute('aria-selected', 'true');
            tab.classList.remove('bg-brand-500', 'text-brand-100');
            tab.classList.add('bg-accent', 'text-brand-700', 'shadow-glow');

            panels.forEach(p => {
              p.classList.toggle('hidden', p.getAttribute('data-panel') !== idx);
            });
          });
        });
      });
    </script>
  </div>
) : (
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
    {ediciones[0]?.episodios.map(ep => (
      <EpisodeCard
        episode={ep}
        href={`${basePath}/${ep.video_id}`}
        canalNombre={ediciones[0]?.canal?.nombre}
      />
    ))}
  </div>
)}
