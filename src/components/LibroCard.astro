---
import type { Libro } from '../lib/types';
import { contarEpisodiosLibro } from '../lib/datos';
import { TIPO_LABELS } from '../lib/utils';

interface Props {
  libro: Libro;
  href: string;
}

const { libro, href } = Astro.props;
const totalEps = contarEpisodiosLibro(libro);
const multiEdicion = libro.ediciones.length > 1;
const tipoBadge = libro.ediciones[0]?.tipo ?? 'audiolibro';
const badgeLabel = TIPO_LABELS[tipoBadge] ?? tipoBadge;
---

<a
  href={href}
  class="group block bg-white rounded-xl shadow-card overflow-hidden border border-brand-200/40 hover:border-brand-400/30 hover:shadow-card-hover transition-all duration-500"
>
  {libro.thumbnail && (
    <div class="aspect-video bg-brand-100 overflow-hidden relative">
      <img
        src={libro.thumbnail}
        alt={libro.titulo}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-brand-900/50 via-transparent to-transparent"></div>
      <div class="absolute bottom-2.5 left-3 right-3 flex justify-between items-end">
        {multiEdicion && (
          <span class="bg-brand-400 text-brand-900 text-[10px] font-bold px-2.5 py-1 rounded tracking-wide">
            {libro.ediciones.length} ediciones
          </span>
        )}
        <span class:list={["bg-brand-900/70 text-white text-xs px-2 py-1 rounded backdrop-blur-sm", !multiEdicion && "ml-auto"]}>
          {totalEps} eps
        </span>
      </div>
    </div>
  )}
  <div class="p-4">
    <span class="text-[10px] font-semibold tracking-[0.12em] uppercase text-brand-400">{badgeLabel}</span>
    <h3 class="font-display text-lg font-bold text-brand-800 group-hover:text-brand-600 transition-colors duration-300 mt-1 line-clamp-2 leading-snug">
      {libro.titulo}
    </h3>
    <p class="text-sm text-brand-500 mt-1.5">{libro.autor}</p>
    {!libro.thumbnail && (
      <p class="text-xs text-brand-500/70 mt-1.5">
        {totalEps} {totalEps === 1 ? 'episodio' : 'episodios'}
        {multiEdicion && ` · ${libro.ediciones.length} ediciones`}
      </p>
    )}
  </div>
</a>
