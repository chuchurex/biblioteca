---
import Layout from '../../../layouts/Layout.astro';
import EdicionSelector from '../../../components/EdicionSelector.astro';
import { getAllLibros, getLibroBySlug, getEdicionesDeLLibro, contarEpisodiosLibro } from '../../../lib/datos';
import { TIPO_LABELS } from '../../../lib/utils';

export function getStaticPaths() {
  return getAllLibros().map(libro => ({
    params: { libro: libro.slug },
  }));
}

const { libro: libroSlug } = Astro.params;
const libro = getLibroBySlug(libroSlug!)!;
const ediciones = getEdicionesDeLLibro(libro);
const totalEps = contarEpisodiosLibro(libro);
const multiEdicion = ediciones.length > 1;
const tipoBadge = TIPO_LABELS[libro.ediciones[0]?.tipo] ?? libro.ediciones[0]?.tipo;
---

<Layout
  title={`${libro.titulo} — chuchurex`}
  description={libro.descripcion || `${libro.titulo} — ${libro.autor}`}
>
  <section class="py-10 relative overflow-hidden">
    <div class="absolute top-1/2 right-0 -translate-y-1/2 w-48 h-48 border border-white/[0.03] rounded-full translate-x-1/2"></div>
    <div class="container mx-auto px-6 md:px-12 relative z-10">
      <nav class="text-sm text-brand-200 mb-5">
        <a href="/" class="hover:text-accent transition-colors duration-300">Inicio</a>
        <span class="mx-2 text-brand-200/30">/</span>
        <a href="/libros/" class="hover:text-accent transition-colors duration-300">Contenidos</a>
        <span class="mx-2 text-brand-200/30">/</span>
        <span class="text-brand-50">{libro.titulo}</span>
      </nav>

      <span class="text-[10px] font-semibold tracking-[0.15em] uppercase text-accent">{tipoBadge}</span>
      <h1 class="text-3xl md:text-4xl font-display font-bold text-brand-50 mt-1">{libro.titulo}</h1>
      <p class="mt-2 text-brand-100 text-lg">{libro.autor}</p>
      {libro.descripcion && <p class="mt-3 text-brand-200 max-w-3xl leading-relaxed">{libro.descripcion}</p>}
      <div class="flex items-center gap-4 mt-4 text-[11px] text-brand-200 tracking-[0.1em] uppercase">
        <span>{totalEps} episodios</span>
        {multiEdicion && (
          <>
            <span class="w-1 h-1 rounded-full bg-accent/40"></span>
            <span>{ediciones.length} ediciones</span>
          </>
        )}
      </div>
    </div>
  </section>

  <section class="py-10">
    <div class="container mx-auto px-6 md:px-12">
      <EdicionSelector ediciones={ediciones} basePath={`/libros/${libroSlug}`} />
    </div>
  </section>
</Layout>
