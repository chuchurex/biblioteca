---
import Layout from '../layouts/Layout.astro';
import TemaCard from '../components/TemaCard.astro';
import LibroCard from '../components/LibroCard.astro';
import MeditacionCard from '../components/MeditacionCard.astro';
import { getAllTemas, getAllLibros, getAllMeditaciones, getLibrosByTema, getMeditacionesByTema, contarEpisodiosPorTema, contarEpisodiosLibro, contarEpisodiosMeditacion } from '../lib/datos';

const temas = getAllTemas().filter(t => {
  return getLibrosByTema(t.slug).length > 0 || getMeditacionesByTema(t.slug).length > 0;
});
const libros = getAllLibros();
const meditaciones = getAllMeditaciones();

const totalTemas = temas.length;
const totalEpisodios = temas.reduce((sum, t) => sum + contarEpisodiosPorTema(t.slug), 0);

const librosRecientes = libros.slice(0, 6);
---

<Layout title="Biblioteca — Libros, meditaciones y crecimiento personal">
  <section class="relative overflow-hidden bg-brand-900 py-20 md:py-32">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] border border-brand-400/[0.07] rounded-full"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[340px] h-[340px] border border-brand-400/[0.05] rounded-full"></div>

    <div class="container mx-auto px-4 md:px-8 text-center relative z-10">
      <div class="flex justify-center mb-6">
        <div class="gold-rule h-px w-16"></div>
      </div>
      <h1 class="text-5xl md:text-7xl font-display font-bold text-white tracking-tight">Biblioteca</h1>
      <p class="mt-5 text-lg md:text-xl text-brand-300 max-w-xl mx-auto leading-relaxed">
        Libros, meditaciones y recursos para el crecimiento personal y la consciencia.
      </p>
      <div class="flex justify-center mt-8">
        <div class="gold-rule h-px w-28"></div>
      </div>
      <p class="mt-5 text-sm text-brand-300/60 tracking-widest uppercase">
        {libros.length} libros &nbsp;&middot;&nbsp; {meditaciones.length} meditaciones &nbsp;&middot;&nbsp; {totalEpisodios.toLocaleString('es-CL')} episodios
      </p>
    </div>
  </section>

  <section class="py-14 md:py-16">
    <div class="container mx-auto px-4 md:px-8">
      <h2 class="text-3xl font-display font-bold text-brand-800 mb-8">Temas</h2>
      <div class="grid gap-4 md:grid-cols-2">
        {temas.map(tema => (
          <TemaCard tema={tema} />
        ))}
      </div>
    </div>
  </section>

  {meditaciones.length > 0 && (
    <section class="py-14 md:py-16 bg-brand-100/50">
      <div class="container mx-auto px-4 md:px-8">
        <div class="flex items-baseline justify-between mb-8">
          <h2 class="text-3xl font-display font-bold text-brand-800">Meditaciones</h2>
          <a href="/meditaciones/" class="text-sm text-brand-500 hover:text-brand-700 transition">
            Ver todas &rarr;
          </a>
        </div>
        <div class="grid gap-6 sm:grid-cols-2 md:grid-cols-3">
          {meditaciones.map(med => (
            <MeditacionCard meditacion={med} href={`/meditaciones/${med.slug}/`} />
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="py-14 md:py-16">
    <div class="container mx-auto px-4 md:px-8">
      <div class="flex items-baseline justify-between mb-8">
        <h2 class="text-3xl font-display font-bold text-brand-800">Libros</h2>
        <a href="/libros/" class="text-sm text-brand-500 hover:text-brand-700 transition">
          Ver todos &rarr;
        </a>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 md:grid-cols-3">
        {librosRecientes.map(libro => (
          <LibroCard libro={libro} href={`/libros/${libro.slug}/`} />
        ))}
      </div>
    </div>
  </section>
</Layout>
