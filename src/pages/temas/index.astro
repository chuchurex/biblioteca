---
import Layout from '../../layouts/Layout.astro';
import TemaCard from '../../components/TemaCard.astro';
import { getAllTemas, getLibrosByTema, getMeditacionesByTema, contarEpisodiosPorTema } from '../../lib/datos';

const temas = getAllTemas().filter(t =>
  getLibrosByTema(t.slug).length > 0 || getMeditacionesByTema(t.slug).length > 0
);
const totalEpisodios = temas.reduce((sum, t) => sum + contarEpisodiosPorTema(t.slug), 0);
---

<Layout
  title="Temas — chuchurex"
  description="Explora los temas: consciencia, meditación, tradiciones orientales y más."
>
  <section class="py-12 relative overflow-hidden">
    <div class="absolute top-1/2 right-0 -translate-y-1/2 w-64 h-64 border border-white/[0.03] rounded-full translate-x-1/2"></div>
    <div class="container mx-auto px-6 md:px-12 relative z-10">
      <nav class="text-sm text-brand-200 mb-5">
        <a href="/" class="hover:text-accent transition-colors duration-300">Inicio</a>
        <span class="mx-2 text-brand-200/30">/</span>
        <span class="text-brand-50">Temas</span>
      </nav>
      <h1 class="text-4xl md:text-5xl font-display font-bold text-brand-50">Temas</h1>
      <p class="mt-3 text-brand-100 max-w-3xl leading-relaxed">
        Explora el contenido organizado por áreas de conocimiento.
      </p>
      <div class="flex items-center gap-4 mt-4 text-[11px] text-brand-200 tracking-[0.1em] uppercase">
        <span>{temas.length} temas</span>
        <span class="w-1 h-1 rounded-full bg-accent/40"></span>
        <span>{totalEpisodios} episodios</span>
      </div>
    </div>
  </section>

  <section class="py-10">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        {temas.map(tema => (
          <TemaCard tema={tema} />
        ))}
      </div>
    </div>
  </section>
</Layout>
