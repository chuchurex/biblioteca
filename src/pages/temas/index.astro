---
import Layout from '../../layouts/Layout.astro';
import TemaCard from '../../components/TemaCard.astro';
import { getAllTemas, getLibrosByTema, getMeditacionesByTema, contarEpisodiosPorTema } from '../../lib/datos';

const temas = getAllTemas().filter(t =>
  getLibrosByTema(t.slug).length > 0 || getMeditacionesByTema(t.slug).length > 0
);
const totalEpisodios = temas.reduce((sum, t) => sum + contarEpisodiosPorTema(t.slug), 0);
---

<Layout
  title="Temas — Biblioteca"
  description="Explora los temas de la Biblioteca: consciencia, meditación, tradiciones orientales y más."
>
  <section class="bg-brand-900 text-white py-12 relative overflow-hidden">
    <div class="absolute top-1/2 right-0 -translate-y-1/2 w-64 h-64 border border-brand-400/[0.06] rounded-full translate-x-1/2"></div>
    <div class="container mx-auto px-4 md:px-8 relative z-10">
      <nav class="text-sm text-brand-300/60 mb-5">
        <a href="/" class="hover:text-brand-400 transition-colors duration-300">Inicio</a>
        <span class="mx-2 text-brand-300/30">/</span>
        <span class="text-white/90">Temas</span>
      </nav>
      <h1 class="text-3xl md:text-4xl font-display font-bold">Temas</h1>
      <p class="mt-3 text-brand-300/80 max-w-3xl leading-relaxed">
        Explora el contenido organizado por áreas de conocimiento.
      </p>
      <div class="flex items-center gap-4 mt-4 text-[11px] text-brand-300/50 tracking-[0.1em] uppercase">
        <span>{temas.length} temas</span>
        <span class="w-1 h-1 rounded-full bg-brand-400/40"></span>
        <span>{totalEpisodios} episodios</span>
      </div>
    </div>
  </section>

  <section class="py-10">
    <div class="container mx-auto px-4 md:px-8">
      <div class="grid gap-4 md:grid-cols-2">
        {temas.map(tema => (
          <TemaCard tema={tema} />
        ))}
      </div>
    </div>
  </section>
</Layout>
