---
import Layout from '../../../layouts/Layout.astro';
import LibroCard from '../../../components/LibroCard.astro';
import MeditacionCard from '../../../components/MeditacionCard.astro';
import { getAllTemas, getTemaBySlug, getContenidoPorAutor, contarEpisodiosPorTema, contarEpisodiosLibro, contarEpisodiosMeditacion, getLibrosByTema, getMeditacionesByTema } from '../../../lib/datos';
import type { Tema } from '../../../lib/types';

export function getStaticPaths() {
  return getAllTemas()
    .filter(t => getLibrosByTema(t.slug).length > 0 || getMeditacionesByTema(t.slug).length > 0)
    .map(t => ({
      params: { tema: t.slug },
    }));
}

const { tema: temaSlug } = Astro.params;
const tema = getTemaBySlug(temaSlug!) as Tema;
const grupos = getContenidoPorAutor(temaSlug!);
const libros = getLibrosByTema(temaSlug!);
const meditaciones = getMeditacionesByTema(temaSlug!);
const totalEpisodios = contarEpisodiosPorTema(temaSlug!);
const totalTitulos = libros.length + meditaciones.length;
---

<Layout
  title={`${tema.nombre} — Biblioteca`}
  description={tema.descripcion}
>
  <section class="bg-brand-900 text-white py-12 relative overflow-hidden">
    <div class="absolute top-1/2 right-0 -translate-y-1/2 w-64 h-64 border border-brand-400/[0.06] rounded-full translate-x-1/2"></div>
    <div class="container mx-auto px-4 md:px-8 relative z-10">
      <nav class="text-sm text-brand-300/60 mb-5">
        <a href="/" class="hover:text-brand-400 transition-colors duration-300">Inicio</a>
        <span class="mx-2 text-brand-300/30">/</span>
        <span class="text-white/90">{tema.nombre}</span>
      </nav>
      <h1 class="text-3xl md:text-4xl font-display font-bold">{tema.nombre}</h1>
      <p class="mt-3 text-brand-300/80 max-w-3xl leading-relaxed">{tema.descripcion}</p>
      <div class="flex items-center gap-4 mt-4 text-[11px] text-brand-300/50 tracking-[0.1em] uppercase">
        <span>{totalTitulos} {totalTitulos === 1 ? 'título' : 'títulos'}</span>
        <span class="w-1 h-1 rounded-full bg-brand-400/40"></span>
        <span>{totalEpisodios} episodios</span>
      </div>
    </div>
  </section>

  {grupos.map((grupo, i) => {
    const autorEps = grupo.libros.reduce((sum, l) => sum + contarEpisodiosLibro(l), 0)
      + grupo.meditaciones.reduce((sum, m) => sum + contarEpisodiosMeditacion(m), 0);
    return (
      <section class:list={["py-10", i > 0 && "border-t border-brand-200/60"]}>
        <div class="container mx-auto px-4 md:px-8">
          <div class="mb-6">
            <h2 class="text-2xl font-display font-bold text-brand-800">{grupo.autor}</h2>
            <p class="text-sm text-brand-500/70 mt-1">
              {grupo.libros.length + grupo.meditaciones.length} {(grupo.libros.length + grupo.meditaciones.length) === 1 ? 'título' : 'títulos'} &middot; {autorEps} episodios
            </p>
          </div>
          <div class="grid gap-6 sm:grid-cols-2 md:grid-cols-3">
            {grupo.libros.map(libro => (
              <LibroCard libro={libro} href={`/libros/${libro.slug}/`} />
            ))}
            {grupo.meditaciones.map(med => (
              <MeditacionCard meditacion={med} href={`/meditaciones/${med.slug}/`} />
            ))}
          </div>
        </div>
      </section>
    );
  })}
</Layout>
