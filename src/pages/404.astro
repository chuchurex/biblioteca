---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página no encontrada — chuchurex" description="La página que buscas no existe o fue movida.">
  <section class="flex flex-col items-center justify-center py-24 px-4 text-center">
    <span class="text-8xl font-display font-bold text-brand-200/30">404</span>
    <h1 class="mt-4 text-3xl font-display font-bold text-brand-50">Página no encontrada</h1>
    <p class="mt-3 text-lg text-brand-100 max-w-md">
      La página que buscas no existe o fue movida.
    </p>
    <div class="mt-8 flex flex-wrap gap-4 justify-center">
      <a
        href="/"
        class="px-6 py-3 rounded-lg bg-accent text-brand-700 font-semibold hover:bg-[#F0BC5A] hover:shadow-glow transition-all duration-300"
      >
        Ir al inicio
      </a>
      <a
        href="/libros/"
        class="px-6 py-3 rounded-lg border border-white/10 text-brand-50 font-medium hover:bg-white/[0.08] transition-all duration-300"
      >
        Ver contenidos
      </a>
    </div>
  </section>
</Layout>
