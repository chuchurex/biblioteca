---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página no encontrada — Biblioteca" description="La página que buscas no existe o fue movida.">
  <section class="flex flex-col items-center justify-center py-24 px-4 text-center">
    <span class="text-8xl font-bold text-brand-300">404</span>
    <h1 class="mt-4 text-3xl font-bold text-brand-900">Página no encontrada</h1>
    <p class="mt-3 text-lg text-brand-600 max-w-md">
      La página que buscas no existe o fue movida.
    </p>
    <div class="mt-8 flex flex-wrap gap-4 justify-center">
      <a
        href="/"
        class="px-6 py-3 rounded-lg bg-brand-600 text-white font-medium hover:bg-brand-700 transition"
      >
        Ir al inicio
      </a>
      <a
        href="/canales/"
        class="px-6 py-3 rounded-lg border border-brand-300 text-brand-700 font-medium hover:bg-brand-100 transition"
      >
        Ver canales
      </a>
    </div>
  </section>
</Layout>
