---
import Layout from '../../layouts/Layout.astro';
import MeditacionCard from '../../components/MeditacionCard.astro';
import { getAllMeditaciones, contarEpisodiosMeditacion } from '../../lib/datos';

const meditaciones = getAllMeditaciones();
const totalEps = meditaciones.reduce((sum, m) => sum + contarEpisodiosMeditacion(m), 0);
---

<Layout
  title="Meditaciones — Biblioteca"
  description="Meditaciones guiadas para la práctica diaria. Videos, audios y textos para el crecimiento interior."
>
  <section class="bg-brand-900 text-white py-12 relative overflow-hidden">
    <div class="absolute top-1/2 right-0 -translate-y-1/2 w-64 h-64 border border-brand-400/[0.06] rounded-full translate-x-1/2"></div>
    <div class="container mx-auto px-4 md:px-8 relative z-10">
      <nav class="text-sm text-brand-300/60 mb-5">
        <a href="/" class="hover:text-brand-400 transition-colors duration-300">Inicio</a>
        <span class="mx-2 text-brand-300/30">/</span>
        <span class="text-white/90">Meditaciones</span>
      </nav>
      <h1 class="text-3xl md:text-4xl font-display font-bold">Meditaciones</h1>
      <p class="mt-3 text-brand-300/80 max-w-3xl leading-relaxed">
        Meditaciones guiadas para la práctica diaria. Videos y audios para el crecimiento interior.
      </p>
      <div class="flex items-center gap-4 mt-4 text-[11px] text-brand-300/50 tracking-[0.1em] uppercase">
        <span>{meditaciones.length} {meditaciones.length === 1 ? 'colección' : 'colecciones'}</span>
        <span class="w-1 h-1 rounded-full bg-brand-400/40"></span>
        <span>{totalEps} episodios</span>
      </div>
    </div>
  </section>

  <section class="py-10">
    <div class="container mx-auto px-4 md:px-8">
      <div class="grid gap-6 sm:grid-cols-2 md:grid-cols-3">
        {meditaciones.map(med => (
          <MeditacionCard meditacion={med} href={`/meditaciones/${med.slug}/`} />
        ))}
      </div>
    </div>
  </section>
</Layout>
