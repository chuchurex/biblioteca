---
import Layout from '../../layouts/Layout.astro';
import MeditacionCard from '../../components/MeditacionCard.astro';
import { getAllMeditaciones, contarEpisodiosMeditacion } from '../../lib/datos';

const meditaciones = getAllMeditaciones();
const totalEps = meditaciones.reduce((sum, m) => sum + contarEpisodiosMeditacion(m), 0);
---

<Layout
  title="Meditaciones — chuchurex"
  description="Meditaciones guiadas para la práctica diaria. Videos y audios para el crecimiento interior."
>
  <section class="py-12 relative overflow-hidden">
    <div class="absolute top-1/2 right-0 -translate-y-1/2 w-64 h-64 border border-white/[0.03] rounded-full translate-x-1/2"></div>
    <div class="container mx-auto px-6 md:px-12 relative z-10">
      <nav class="text-sm text-brand-200 mb-5">
        <a href="/" class="hover:text-accent transition-colors duration-300">Inicio</a>
        <span class="mx-2 text-brand-200/30">/</span>
        <span class="text-brand-50">Meditaciones</span>
      </nav>
      <h1 class="text-4xl md:text-5xl font-display font-bold text-brand-50">Meditaciones</h1>
      <p class="mt-3 text-brand-100 max-w-3xl leading-relaxed">
        Meditaciones guiadas para la práctica diaria. Videos y audios para el crecimiento interior.
      </p>
      <div class="flex items-center gap-4 mt-4 text-[11px] text-brand-200 tracking-[0.1em] uppercase">
        <span>{meditaciones.length} {meditaciones.length === 1 ? 'colección' : 'colecciones'}</span>
        <span class="w-1 h-1 rounded-full bg-accent/40"></span>
        <span>{totalEps} episodios</span>
      </div>
    </div>
  </section>

  <section class="py-10">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid gap-6 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
        {meditaciones.map(med => (
          <MeditacionCard meditacion={med} href={`/meditaciones/${med.slug}/`} />
        ))}
      </div>
    </div>
  </section>
</Layout>
