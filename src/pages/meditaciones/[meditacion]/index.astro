---
import Layout from '../../../layouts/Layout.astro';
import EpisodeCard from '../../../components/EpisodeCard.astro';
import { getAllMeditaciones, getMeditacionBySlug, getVersionesDeMeditacion, contarEpisodiosMeditacion } from '../../../lib/datos';

export function getStaticPaths() {
  return getAllMeditaciones().map(med => ({
    params: { meditacion: med.slug },
  }));
}

const { meditacion: medSlug } = Astro.params;
const med = getMeditacionBySlug(medSlug!)!;
const versiones = getVersionesDeMeditacion(med);
const totalEps = contarEpisodiosMeditacion(med);
---

<Layout
  title={`${med.titulo} — Biblioteca`}
  description={med.descripcion || `${med.titulo} — ${med.guia}`}
>
  <section class="bg-brand-900 text-white py-10 relative overflow-hidden">
    <div class="absolute top-1/2 right-0 -translate-y-1/2 w-48 h-48 border border-brand-400/[0.06] rounded-full translate-x-1/2"></div>
    <div class="container mx-auto px-4 md:px-8 relative z-10">
      <nav class="text-sm text-brand-300/60 mb-5">
        <a href="/" class="hover:text-brand-400 transition-colors duration-300">Inicio</a>
        <span class="mx-2 text-brand-300/30">/</span>
        <a href="/meditaciones/" class="hover:text-brand-400 transition-colors duration-300">Meditaciones</a>
        <span class="mx-2 text-brand-300/30">/</span>
        <span class="text-white/90">{med.titulo}</span>
      </nav>

      <span class="text-[10px] font-semibold tracking-[0.15em] uppercase text-brand-400">Meditación{med.tipo ? ` ${med.tipo}` : ''}</span>
      <h1 class="text-3xl md:text-4xl font-display font-bold mt-1">{med.titulo}</h1>
      <p class="mt-2 text-brand-300/80 text-lg">{med.guia}</p>
      {med.descripcion && <p class="mt-3 text-brand-300/60 max-w-3xl leading-relaxed">{med.descripcion}</p>}
      <div class="flex items-center gap-4 mt-4 text-[11px] text-brand-300/50 tracking-[0.1em] uppercase">
        <span>{totalEps} episodios</span>
      </div>
    </div>
  </section>

  <section class="py-10">
    <div class="container mx-auto px-4 md:px-8">
      {versiones.map((v, i) => (
        <div class:list={[i > 0 && "mt-10"]}>
          {versiones.length > 1 && (
            <h2 class="text-xl font-display font-bold text-brand-800 mb-4">
              {v.version.nombre}
              <span class="text-sm font-body font-normal text-brand-500/70 ml-2">({v.episodios.length} eps)</span>
            </h2>
          )}
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
            {v.episodios.map(ep => (
              <EpisodeCard
                episode={ep}
                href={`/meditaciones/${medSlug}/${ep.video_id}`}
                canalNombre={v.canal?.nombre}
              />
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>
