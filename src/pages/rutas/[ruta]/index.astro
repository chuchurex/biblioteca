---
import Layout from '../../../layouts/Layout.astro';
import { getAllRutas, getRutaBySlug, getLibroBySlug, getMeditacionBySlug, getTemaBySlug, contarEpisodiosLibro, contarEpisodiosMeditacion } from '../../../lib/datos';
import type { Ruta } from '../../../lib/types';

export function getStaticPaths() {
  return getAllRutas().map(ruta => ({
    params: { ruta: ruta.slug },
  }));
}

const { ruta: rutaSlug } = Astro.params;
const ruta = getRutaBySlug(rutaSlug) as Ruta;
const temas = ruta.temas.map(s => getTemaBySlug(s)).filter(Boolean);

const nivelLabels: Record<string, string> = {
  principiante: 'Principiante',
  intermedio: 'Intermedio',
  avanzado: 'Avanzado',
};

const pasos = ruta.pasos.map(paso => {
  if (paso.tipo === 'libro') {
    const libro = getLibroBySlug(paso.ref)!;
    return {
      ...paso,
      titulo: libro.titulo,
      subtitulo: libro.autor,
      thumbnail: libro.thumbnail,
      href: `/libros/${libro.slug}/`,
      episodios: contarEpisodiosLibro(libro),
      badge: 'Libro',
    };
  }
  const med = getMeditacionBySlug(paso.ref)!;
  return {
    ...paso,
    titulo: med.titulo,
    subtitulo: med.guia,
    thumbnail: med.thumbnail,
    href: `/meditaciones/${med.slug}/`,
    episodios: contarEpisodiosMeditacion(med),
    badge: 'Meditación',
  };
});
---

<Layout
  title={`${ruta.titulo} — Rutas de estudio — Biblioteca`}
  description={ruta.descripcion}
>
  <section class="bg-brand-900 text-white py-12 relative overflow-hidden">
    <div class="absolute top-1/2 right-0 -translate-y-1/2 w-64 h-64 border border-brand-400/[0.06] rounded-full translate-x-1/2"></div>
    <div class="container mx-auto px-4 md:px-8 relative z-10">
      <nav class="text-sm text-brand-300/60 mb-5">
        <a href="/" class="hover:text-brand-400 transition-colors duration-300">Inicio</a>
        <span class="mx-2 text-brand-300/30">/</span>
        <a href="/rutas/" class="hover:text-brand-400 transition-colors duration-300">Rutas</a>
        <span class="mx-2 text-brand-300/30">/</span>
        <span class="text-white/90">{ruta.titulo}</span>
      </nav>
      <div class="flex flex-wrap items-center gap-3 mb-3">
        <span class="text-[10px] font-semibold tracking-[0.12em] uppercase bg-brand-400/20 text-brand-400 px-2.5 py-1 rounded">
          {nivelLabels[ruta.nivel] ?? ruta.nivel}
        </span>
        {ruta.duracion_estimada && (
          <span class="text-[11px] text-brand-300/60">{ruta.duracion_estimada}</span>
        )}
        {temas.map(t => (
          <a href={`/temas/${t!.slug}/`} class="text-[11px] text-brand-300/60 hover:text-brand-400 transition-colors duration-300">
            {t!.nombre}
          </a>
        ))}
      </div>
      <h1 class="text-3xl md:text-4xl font-display font-bold">{ruta.titulo}</h1>
      <p class="mt-3 text-brand-300/80 max-w-3xl leading-relaxed">{ruta.descripcion}</p>
      <div class="flex items-center gap-4 mt-4 text-[11px] text-brand-300/50 tracking-[0.1em] uppercase">
        <span>{ruta.pasos.length} {ruta.pasos.length === 1 ? 'paso' : 'pasos'}</span>
      </div>
    </div>
  </section>

  <section class="py-10 md:py-14">
    <div class="container mx-auto px-4 md:px-8 max-w-3xl">
      <div class="relative">
        {/* Línea vertical de timeline */}
        <div class="absolute left-5 top-0 bottom-0 w-px bg-brand-200/60 md:left-6"></div>

        {pasos.map((paso, i) => (
          <div class:list={["relative pl-14 md:pl-16 pb-10", i === pasos.length - 1 && "pb-0"]}>
            {/* Número del paso */}
            <div class="absolute left-0 top-0 w-10 h-10 md:w-12 md:h-12 rounded-full bg-brand-900 text-white flex items-center justify-center font-display font-bold text-lg border-2 border-brand-400/30 z-10">
              {paso.orden}
            </div>

            <a
              href={paso.href}
              class="group block bg-white rounded-xl shadow-card overflow-hidden border border-brand-200/40 hover:border-brand-400/30 hover:shadow-card-hover transition-all duration-500"
            >
              <div class="flex flex-col sm:flex-row">
                {paso.thumbnail && (
                  <div class="sm:w-40 sm:flex-shrink-0">
                    <img
                      src={paso.thumbnail}
                      alt={paso.titulo}
                      class="w-full h-32 sm:h-full object-cover group-hover:scale-105 transition-transform duration-700"
                      loading="lazy"
                    />
                  </div>
                )}
                <div class="p-4 flex-1">
                  <div class="flex items-center gap-2 mb-1">
                    <span class="text-[10px] font-semibold tracking-[0.12em] uppercase text-brand-400">{paso.badge}</span>
                    <span class="text-[10px] text-brand-500/50">{paso.episodios} eps</span>
                  </div>
                  <h3 class="font-display text-lg font-bold text-brand-800 group-hover:text-brand-600 transition-colors duration-300 leading-snug">
                    {paso.titulo}
                  </h3>
                  <p class="text-sm text-brand-500 mt-1">{paso.subtitulo}</p>
                  {paso.nota && (
                    <p class="text-sm text-brand-500/70 mt-2 italic">{paso.nota}</p>
                  )}
                </div>
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
