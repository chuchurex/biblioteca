---
import Layout from '../../../layouts/Layout.astro';
import EpisodeCard from '../../../components/EpisodeCard.astro';
import { getAllSeries, getSerieBySlug, getSerieEpisodios, getTemaPrincipal, getCanalDeSerie, getFormatoBySlug } from '../../../lib/datos';

export function getStaticPaths() {
  const series = getAllSeries();
  return series.map(s => ({
    params: {
      tema: s.temas[0],
      serie: s.slug,
    },
  }));
}

const { tema: temaSlug, serie: serieSlug } = Astro.params;
const serie = getSerieBySlug(serieSlug!)!;
const tema = getTemaPrincipal(serie)!;
const canal = getCanalDeSerie(serie);
const formato = getFormatoBySlug(serie.formato);
const episodios = getSerieEpisodios(serie);
---

<Layout
  title={`${serie.nombre} — ${tema.nombre} — Biblioteca`}
  description={serie.descripcion || `Episodios de ${serie.nombre}.`}
>
  <section class="bg-brand-900 text-white py-10">
    <div class="container mx-auto px-4 md:px-8">
      <nav class="text-sm text-brand-300 mb-4">
        <a href="/" class="hover:text-white transition">Inicio</a>
        <span class="mx-2">/</span>
        <a href={`/${temaSlug}/`} class="hover:text-white transition">{tema.nombre}</a>
        <span class="mx-2">/</span>
        <span class="text-white">{serie.nombre}</span>
      </nav>
      <h1 class="text-3xl font-bold">{serie.nombre}</h1>
      {serie.descripcion && (
        <p class="mt-2 text-brand-200 max-w-3xl">{serie.descripcion}</p>
      )}
      <div class="flex flex-wrap items-center gap-3 mt-3 text-sm text-brand-300">
        <span>{episodios.length} episodios</span>
        {formato && (
          <>
            <span>&middot;</span>
            <span>{formato.nombre}</span>
          </>
        )}
        {canal && (
          <>
            <span>&middot;</span>
            <span>{canal.nombre}</span>
          </>
        )}
        {serie.idioma && serie.idioma !== 'es' && (
          <>
            <span>&middot;</span>
            <span class="uppercase">{serie.idioma}</span>
          </>
        )}
      </div>
    </div>
  </section>

  <section class="py-10">
    <div class="container mx-auto px-4 md:px-8">
      <div class="grid gap-6 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
        {episodios.map(ep => (
          <EpisodeCard
            episode={ep}
            href={`/${temaSlug}/${serieSlug}/${ep.video_id}`}
          />
        ))}
      </div>
    </div>
  </section>
</Layout>
