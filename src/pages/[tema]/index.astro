---
import Layout from '../../layouts/Layout.astro';
import SerieCard from '../../components/SerieCard.astro';
import { getAllTemas, getTemaBySlug, getSeriesByTema, contarEpisodiosPorTema } from '../../lib/datos';
import type { Tema } from '../../lib/types';

export function getStaticPaths() {
  return getAllTemas().map(t => ({
    params: { tema: t.slug },
  }));
}

const { tema: temaSlug } = Astro.params;
const tema = getTemaBySlug(temaSlug!) as Tema;
const series = getSeriesByTema(temaSlug!);
const totalEpisodios = contarEpisodiosPorTema(temaSlug!);
---

<Layout
  title={`${tema.nombre} — Biblioteca`}
  description={tema.descripcion}
>
  <section class="bg-brand-900 text-white py-12">
    <div class="container mx-auto px-4 md:px-8">
      <nav class="text-sm text-brand-300 mb-4">
        <a href="/" class="hover:text-white transition">Inicio</a>
        <span class="mx-2">/</span>
        <span class="text-white">{tema.nombre}</span>
      </nav>
      <div class="flex items-center gap-3 mb-2">
        {tema.icono && <span class="text-3xl">{tema.icono}</span>}
        <h1 class="text-3xl font-bold">{tema.nombre}</h1>
      </div>
      <p class="mt-2 text-brand-200 max-w-3xl">{tema.descripcion}</p>
      <p class="mt-2 text-sm text-brand-300">
        {series.length} {series.length === 1 ? 'serie' : 'series'} &middot; {totalEpisodios} episodios
      </p>
    </div>
  </section>

  <section class="py-10">
    <div class="container mx-auto px-4 md:px-8">
      <div class="grid gap-6 sm:grid-cols-2 md:grid-cols-3">
        {series.map(serie => (
          <SerieCard
            serie={serie}
            href={`/${temaSlug}/${serie.slug}/`}
          />
        ))}
      </div>
    </div>
  </section>
</Layout>
