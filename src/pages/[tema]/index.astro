---
import Layout from '../../layouts/Layout.astro';
import ObraCard from '../../components/ObraCard.astro';
import SerieCard from '../../components/SerieCard.astro';
import { getAllTemas, getTemaBySlug, getContenidoPorTema, contarEpisodiosPorTema } from '../../lib/datos';
import type { Tema } from '../../lib/types';

export function getStaticPaths() {
  return getAllTemas().map(t => ({
    params: { tema: t.slug },
  }));
}

const { tema: temaSlug } = Astro.params;
const tema = getTemaBySlug(temaSlug!) as Tema;
const { obras, series } = getContenidoPorTema(temaSlug!);
const totalEpisodios = contarEpisodiosPorTema(temaSlug!);
const totalItems = obras.length + series.length;
---

<Layout
  title={`${tema.nombre} — Biblioteca`}
  description={tema.descripcion}
>
  <section class="bg-brand-900 text-white py-12">
    <div class="container mx-auto px-4 md:px-8">
      <nav class="text-sm text-brand-300 mb-4">
        <a href="/" class="hover:text-white transition">Inicio</a>
        <span class="mx-2">/</span>
        <span class="text-white">{tema.nombre}</span>
      </nav>
      <div class="flex items-center gap-3 mb-2">
        {tema.icono && <span class="text-3xl">{tema.icono}</span>}
        <h1 class="text-3xl font-bold">{tema.nombre}</h1>
      </div>
      <p class="mt-2 text-brand-200 max-w-3xl">{tema.descripcion}</p>
      <p class="mt-2 text-sm text-brand-300">
        {totalItems} {totalItems === 1 ? 'título' : 'títulos'} &middot; {totalEpisodios} episodios
      </p>
    </div>
  </section>

  {obras.length > 0 && (
    <section class="py-10">
      <div class="container mx-auto px-4 md:px-8">
        {series.length > 0 && (
          <h2 class="text-xl font-bold text-brand-800 mb-6">Audiolibros</h2>
        )}
        <div class="grid gap-6 sm:grid-cols-2 md:grid-cols-3">
          {obras.map(obra => (
            <ObraCard
              obra={obra}
              href={`/${temaSlug}/${obra.slug}/`}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  {series.length > 0 && (
    <section class:list={["py-10", obras.length > 0 && "border-t border-brand-200"]}>
      <div class="container mx-auto px-4 md:px-8">
        {obras.length > 0 && (
          <h2 class="text-xl font-bold text-brand-800 mb-6">Cursos, clases y más</h2>
        )}
        <div class="grid gap-6 sm:grid-cols-2 md:grid-cols-3">
          {series.map(serie => (
            <SerieCard
              serie={serie}
              href={`/${temaSlug}/${serie.slug}/`}
            />
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>
