---
import Layout from '../../layouts/Layout.astro';
import ObraCard from '../../components/ObraCard.astro';
import SerieCard from '../../components/SerieCard.astro';
import { getAllTemas, getTemaBySlug, getContenidoPorAutor, contarEpisodiosPorTema, contarEpisodiosObra, getSerieEpisodios } from '../../lib/datos';
import type { Tema } from '../../lib/types';

export function getStaticPaths() {
  return getAllTemas().map(t => ({
    params: { tema: t.slug },
  }));
}

const { tema: temaSlug } = Astro.params;
const tema = getTemaBySlug(temaSlug!) as Tema;
const grupos = getContenidoPorAutor(temaSlug!);
const totalEpisodios = contarEpisodiosPorTema(temaSlug!);
const totalTitulos = grupos.reduce((sum, g) => sum + g.obras.length + g.series.length, 0);
---

<Layout
  title={`${tema.nombre} — Biblioteca`}
  description={tema.descripcion}
>
  <section class="bg-brand-900 text-white py-12">
    <div class="container mx-auto px-4 md:px-8">
      <nav class="text-sm text-brand-300 mb-4">
        <a href="/" class="hover:text-white transition">Inicio</a>
        <span class="mx-2">/</span>
        <span class="text-white">{tema.nombre}</span>
      </nav>
      <div class="flex items-center gap-3 mb-2">
        {tema.icono && <span class="text-3xl">{tema.icono}</span>}
        <h1 class="text-3xl font-bold">{tema.nombre}</h1>
      </div>
      <p class="mt-2 text-brand-200 max-w-3xl">{tema.descripcion}</p>
      <p class="mt-2 text-sm text-brand-300">
        {totalTitulos} {totalTitulos === 1 ? 'título' : 'títulos'} &middot; {totalEpisodios} episodios
      </p>
    </div>
  </section>

  {grupos.map((grupo, i) => {
    const autorEps = grupo.obras.reduce((sum, o) => sum + contarEpisodiosObra(o), 0)
      + grupo.series.reduce((sum, s) => sum + getSerieEpisodios(s).length, 0);
    return (
      <section class:list={["py-10", i > 0 && "border-t border-brand-200"]}>
        <div class="container mx-auto px-4 md:px-8">
          <div class="mb-6">
            <h2 class="text-xl font-bold text-brand-800">{grupo.autor}</h2>
            <p class="text-sm text-brand-400 mt-1">
              {grupo.obras.length + grupo.series.length} {(grupo.obras.length + grupo.series.length) === 1 ? 'título' : 'títulos'} &middot; {autorEps} episodios
            </p>
          </div>
          <div class="grid gap-6 sm:grid-cols-2 md:grid-cols-3">
            {grupo.obras.map(obra => (
              <ObraCard obra={obra} href={`/${temaSlug}/${obra.slug}/`} />
            ))}
            {grupo.series.map(serie => (
              <SerieCard serie={serie} href={`/${temaSlug}/${serie.slug}/`} />
            ))}
          </div>
        </div>
      </section>
    );
  })}
</Layout>
