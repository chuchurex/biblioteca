---
import Layout from '../../../layouts/Layout.astro';
import EpisodeCard from '../../../components/EpisodeCard.astro';
import VersionSelector from '../../../components/VersionSelector.astro';
import {
  getAllObras, getAllSeries,
  getSerieEpisodios, getCanalDeSerie, getFormatoBySlug,
  getVersionesDeLaObra, seriePertenecAObra,
  getTemaBySlug,
} from '../../../lib/datos';
import type { Obra, Serie, Tema } from '../../../lib/types';

interface ObraProps { tipo: 'obra'; obra: Obra }
interface SerieProps { tipo: 'serie'; serie: Serie }

export function getStaticPaths() {
  const paths: { params: { tema: string; contenido: string }; props: ObraProps | SerieProps }[] = [];

  for (const obra of getAllObras()) {
    paths.push({
      params: { tema: obra.temas[0], contenido: obra.slug },
      props: { tipo: 'obra', obra },
    });
  }

  for (const serie of getAllSeries()) {
    if (seriePertenecAObra(serie.slug)) continue;
    paths.push({
      params: { tema: serie.temas[0], contenido: serie.slug },
      props: { tipo: 'serie', serie },
    });
  }

  return paths;
}

const { tema: temaSlug, contenido: contenidoSlug } = Astro.params;
const allProps = Astro.props as ObraProps | SerieProps;
const tema = getTemaBySlug(temaSlug!) as Tema;
const isObra = allProps.tipo === 'obra';
---

<Layout
  title={`${isObra ? (allProps as ObraProps).obra.titulo : (allProps as SerieProps).serie.nombre} — ${tema.nombre} — Biblioteca`}
  description={isObra ? (allProps as ObraProps).obra.descripcion : ((allProps as SerieProps).serie.descripcion || `Episodios de ${(allProps as SerieProps).serie.nombre}.`)}
>
  <section class="bg-brand-900 text-white py-10">
    <div class="container mx-auto px-4 md:px-8">
      <nav class="text-sm text-brand-300 mb-4">
        <a href="/" class="hover:text-white transition">Inicio</a>
        <span class="mx-2">/</span>
        <a href={`/${temaSlug}/`} class="hover:text-white transition">{tema.nombre}</a>
        <span class="mx-2">/</span>
        <span class="text-white">{isObra ? (allProps as ObraProps).obra.titulo : (allProps as SerieProps).serie.nombre}</span>
      </nav>

      {isObra ? (() => {
        const obra = (allProps as ObraProps).obra;
        const versiones = getVersionesDeLaObra(obra).map(s => ({
          serie: s, canal: getCanalDeSerie(s), episodios: getSerieEpisodios(s),
        }));
        const totalEps = versiones.reduce((sum, v) => sum + v.episodios.length, 0);
        return (
          <>
            <h1 class="text-3xl font-bold">{obra.titulo}</h1>
            <p class="mt-1 text-brand-200 text-lg">{obra.autor}</p>
            {obra.descripcion && <p class="mt-2 text-brand-200 max-w-3xl">{obra.descripcion}</p>}
            <div class="flex flex-wrap items-center gap-3 mt-3 text-sm text-brand-300">
              <span>{totalEps} episodios</span>
              {versiones.length > 1 && <><span>&middot;</span><span>{versiones.length} versiones</span></>}
            </div>
          </>
        );
      })() : (() => {
        const serie = (allProps as SerieProps).serie;
        const canal = getCanalDeSerie(serie);
        const formato = getFormatoBySlug(serie.formato);
        const episodios = getSerieEpisodios(serie);
        return (
          <>
            <h1 class="text-3xl font-bold">{serie.nombre}</h1>
            {serie.descripcion && <p class="mt-2 text-brand-200 max-w-3xl">{serie.descripcion}</p>}
            <div class="flex flex-wrap items-center gap-3 mt-3 text-sm text-brand-300">
              <span>{episodios.length} episodios</span>
              {formato && <><span>&middot;</span><span>{formato.nombre}</span></>}
              {canal && <><span>&middot;</span><span>{canal.nombre}</span></>}
              {serie.idioma && serie.idioma !== 'es' && <><span>&middot;</span><span class="uppercase">{serie.idioma}</span></>}
            </div>
          </>
        );
      })()}
    </div>
  </section>

  <section class="py-10">
    <div class="container mx-auto px-4 md:px-8">
      {isObra ? (() => {
        const obra = (allProps as ObraProps).obra;
        const versiones = getVersionesDeLaObra(obra).map(s => ({
          serie: s, canal: getCanalDeSerie(s), episodios: getSerieEpisodios(s),
        }));
        return <VersionSelector versiones={versiones} basePath={`/${temaSlug}/${contenidoSlug}`} />;
      })() : (() => {
        const serie = (allProps as SerieProps).serie;
        const episodios = getSerieEpisodios(serie);
        return (
          <div class="grid gap-6 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
            {episodios.map(ep => (
              <EpisodeCard episode={ep} href={`/${temaSlug}/${contenidoSlug}/${ep.video_id}`} />
            ))}
          </div>
        );
      })()}
    </div>
  </section>
</Layout>
